{
  "name": "buddyup-chat-service",
  "version": "1.0.0",
  "description": "BuddyUp Chat Service Backend",
  "main": "src/app.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
    "test": "jest --runInBand",
    "migrate": "node migrations/run.js",
    "setup-firebase": "node setup-firebase.js",
    "verify": "node verify-setup.js",
    "test:firebase": "node test-firebase.js",
    "test:database": "node test-database.js",
    "test:rest": "node test-rest-api.js",
    "test:websocket": "node test-websocket.js",
    "test:s3": "node test-s3-direct.js",
    "test:chat-system": "node test-chat-system.js",
    "test:all": "npm run verify && npm run test:firebase && npm run test:database && npm run test:rest && npm run test:websocket && npm run test:s3 && npm run test:chat-system"
  },
  "dependencies": {
    "@aws-sdk/client-rekognition": "^3.1000.0",
    "@aws-sdk/client-s3": "^3.500.0",
    "@aws-sdk/s3-request-presigner": "^3.500.0",
    "bull": "^4.11.5",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "firebase-admin": "^12.0.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "joi": "^17.11.0",
    "jsonwebtoken": "9.0.2",
    "multer": "^1.4.5-lts.1",
    "multer-s3": "^2.10.0",
    "pg": "^8.11.3",
    "rate-limit-redis": "^4.1.5",
    "sharp": "^0.33.1",
    "socket.io": "^4.7.2",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "socket.io-client": "^4.7.2",
    "supertest": "^6.3.3"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ]
  }
}
